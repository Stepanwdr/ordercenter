# Cloud API base URL
API_URL=https://api.deliverydepartment.am

# This restaurant
RESTAURANT_ID=e81b0277-4e7f-45f1-907b-991ce60f3e12
# Optional: a restaurant with no channelConfig.deviceToken accepts any token (incl. empty)
DEVICE_TOKEN=

# Local thermal printer(s) on this LAN.
# One printer:
PRINTER_IP=192.168.240.23
PRINTER_PORT=9100
# Several printers (kitchen + bar etc.) — the SAME full ticket prints on ALL of them.
# Comma-separated. Each entry: "ip", "ip:port", or "label=ip:port". The label makes the
# config + logs self-documenting (you see which printer is which IP/port). Overrides PRINTER_IP.
# Example:
# PRINTER_IPS=kitchen=192.168.123.100:9100,bar=192.168.240.23:9100
PRINTER_IPS=
PRINTER_TYPE=epson
# node-thermal-printer CharacterSet. Use PC866_CYRILLIC2 for Russian tickets.
# Leave empty ONLY for ASCII-only printers. (utf-8 is NOT valid here.)
PRINTER_CHARSET=PC866_CYRILLIC2

# How often to poll the cloud for new orders, in ms (default 4000)
POLL_INTERVAL_MS=4000
